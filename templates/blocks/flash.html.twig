{% set palette = {
  success: 'border-emerald-200 bg-emerald-50 text-emerald-900',
  error: 'border-red-200 bg-red-50 text-red-900',
  danger: 'border-red-200 bg-red-50 text-red-900',
  warning: 'border-amber-200 bg-amber-50 text-amber-900',
  info: 'border-blue-200 bg-blue-50 text-blue-900'
} %}

<div
  id="flash_toasts"
  class="pointer-events-none flex w-[min(92vw,24rem)] flex-col gap-3"
  style="position: fixed; top: 5rem; right: 1rem; z-index: 9999;"
>
  {% for type, messages in app.flashes %}
    {% for message in messages %}
      <div
        class="flash-toast pointer-events-auto rounded-2xl border px-4 py-3 shadow-lg transition duration-300 {{ palette[type]|default('border-slate-200 bg-white text-slate-900') }}"
        role="status"
        aria-live="polite"
      >
        <div class="flex items-start gap-3">
          <p class="flex-1 text-sm font-medium">{{ message }}</p>
          <button
            type="button"
            class="cursor-pointer rounded-md px-2 py-1 text-xs font-semibold opacity-70 hover:opacity-100"
            data-flash-dismiss
            aria-label="Fermer"
          >
            x
          </button>
        </div>
      </div>
    {% endfor %}
  {% endfor %}
</div>

<script>
  (function () {
    const toasts = document.querySelectorAll('#flash_toasts .flash-toast');

    function hideToast(toast) {
      if (!toast || toast.dataset.closing === '1') {
        return;
      }

      toast.dataset.closing = '1';
      toast.classList.add('opacity-0', 'translate-x-2');
      setTimeout(function () {
        toast.remove();
      }, 280);
    }

    toasts.forEach(function (toast) {
      const dismiss = toast.querySelector('[data-flash-dismiss]');
      if (dismiss) {
        dismiss.addEventListener('click', function () {
          hideToast(toast);
        });
      }

      setTimeout(function () {
        hideToast(toast);
      }, 4200);
    });
  })();
</script>

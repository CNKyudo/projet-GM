<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            color: #1a1a2e;
            padding: 40px 20px;
        }
        h1 { font-size: 22px; margin-bottom: 4px; }
        .subtitle { font-size: 13px; color: #555; margin-bottom: 24px; }
        .qr-wrapper { margin: 0 auto 24px; }
        .qr-wrapper img { width: 300px; height: 300px; }
        .info { font-size: 12px; color: #666; margin-top: 8px; }
        .url { font-size: 10px; color: #aaa; margin-top: 4px; font-family: monospace; }
    </style>
</head>
<body>
    <h1>{{ equipmentLabel }}</h1>
    <div class="subtitle">Propriétaire : {{ ownerLabel }}</div>
    <div class="qr-wrapper">
        <img src="data:image/png;base64,{{ pngBase64 }}" alt="QR Code">
    </div>
    <div class="info">Scannez ce QR code pour accéder aux détails de l'équipement.</div>
    <div class="url">{{ url }}</div>
</body>
</html>

{{ form_start(form, { attr: { class: 'space-y-8' } }) }}

  {% if form.vars.errors|length %}
    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      {{ form_errors(form) }}
    </div>
  {% endif %}

  <section class="space-y-4">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.streetAddress.vars.label|default('Rue') }}
        </label>
        {{ form_widget(form.streetAddress, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.streetAddress) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.postalCode.vars.label|default('Code postal') }}
        </label>
        {{ form_widget(form.postalCode, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.postalCode) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.city.vars.label|default('Ville') }}
        </label>
        {{ form_widget(form.city, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.city) }}</div>
      </div>

      <div class="sm:col-span-2">
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.country.vars.label|default('Pays') }}
        </label>
        {{ form_widget(form.country, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.country) }}</div>
      </div>
    </div>
  </section>

  {{ form_rest(form) }}

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-between">
    <a
      href="{{ cancel_path|default(path('address_index')) }}"
      class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
    >
      Annuler
    </a>

    <button
      type="submit"
      class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-5 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue"
    >
      {{ submit_label|default('Enregistrer') }}
    </button>
  </div>

{{ form_end(form) }}

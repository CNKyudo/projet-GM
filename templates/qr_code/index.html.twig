{% extends 'base.html.twig' %}

{% block title %}QR Codes{% endblock %}

{% block body %}
  <div class="h-screen-with-navbar bg-kyudo-equipment pt-16 pb-10 px-4 sm:px-6">
    <div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

      {# --- Header --- #}
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark">QR Codes</h1>
          <p class="mt-1 text-kyudo-gm-grey">Gestion des QR codes associés aux équipements.</p>
        </div>

        <a
          href="{{ path('qr_code.new') }}"
          class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue"
        >
          + Nouveau QR code
        </a>
      </div>

      {# --- Table --- #}
      <div class="mt-8 overflow-x-auto rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white shadow-sm">
        <table class="w-full text-left">
          <thead class="bg-kyudo-washed-blue text-sm text-(--color-kyudo-white)">
            <tr>
              <th class="px-5 py-4 font-medium">UUID</th>
              <th class="px-5 py-4 font-medium">Équipement</th>
              <th class="px-5 py-4 font-medium">Propriétaire</th>
              <th class="px-5 py-4 font-medium">Créé le</th>
              <th class="px-5 py-4 font-medium text-right">Actions</th>
            </tr>
          </thead>

          <tbody class="divide-y divide-slate-100 text-sm">
            {% for qrCode in qrCodes %}
              {% set equipment = qrCode.equipment %}

              <tr class="hover:bg-kyudo-gm-light-grey">
                <td class="px-5 py-4 font-mono text-xs text-kyudo-gm-grey">
                  {{ qrCode.uuid|slice(0, 8) }}…
                </td>

                <td class="px-5 py-4">
                  {% if equipment %}
                    <a
                      href="{{ path('equipment.show', {'id': equipment.id}) }}"
                      class="font-semibold text-kyudo-gm-dark hover:text-kyudo-blue"
                    >
                      #{{ equipment.id }} – {{ equipment.typeName|capitalize }}
                    </a>
                  {% else %}
                    <span class="text-kyudo-gm-grey">—</span>
                  {% endif %}
                </td>

                <td class="px-5 py-4 text-kyudo-gm-dark">
                  {{ equipment and equipment.ownerClub ? equipment.ownerClub.name : '—' }}
                </td>

                <td class="px-5 py-4 text-kyudo-gm-grey">
                  {{ qrCode.createdAt|date('d/m/Y') }}
                </td>

                <td class="px-5 py-4">
                  <div class="flex justify-end gap-2">
                    <a
                      href="{{ path('qr_code.show', {'uuid': qrCode.uuid}) }}"
                      class="rounded-xl border border-kyudo-gm-light-grey bg-kyudo-white px-3 py-2 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
                    >
                      Voir
                    </a>
                    <a
                      href="{{ path('qr_code.edit', {'uuid': qrCode.uuid}) }}"
                      class="rounded-xl border border-kyudo-gm-light-grey bg-kyudo-white px-3 py-2 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
                    >
                      Modifier
                    </a>
                    <form method="post" action="{{ path('qr_code.delete', {'uuid': qrCode.uuid}) }}" onsubmit="return confirm('Supprimer ce QR code ?')">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete_qr_code_' ~ qrCode.uuid) }}">
                      <button
                        type="submit"
                        class="rounded-xl border border-red-200 bg-kyudo-white px-3 py-2 font-medium text-red-600 hover:bg-red-50"
                      >
                        Supprimer
                      </button>
                    </form>
                  </div>
                </td>
              </tr>

            {% else %}
              <tr>
                <td colspan="5" class="px-5 py-10 text-center text-kyudo-gm-dark">
                  Aucun QR code créé pour le moment.
                  <div class="mt-3">
                    <a
                      class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) hover:bg-kyudo-royal-blue"
                      href="{{ path('qr_code.new') }}"
                    >
                      + Créer un QR code
                    </a>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="mt-6 flex justify-center">
        {{ knp_pagination_render(qrCodes) }}
      </div>

    </div>
  </div>
{% endblock %}

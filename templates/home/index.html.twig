{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}
	<div class="bg-kyudo-white">
		<section class="relative flex flex-col md:flex-row">
			<div id="login_display" class="absolute inset-0 bg-kyudo-home bg-cover bg-center bg-kyudo-white md:static md:flex-2">
				<div class="absolute inset-0 bg-black/40 bg-kyudo-home md:hidden"></div>
			</div>

			<div class="split-banner group">
				<a href="{{ path('equipment.index') }}" class="split-col split-materiel hover:flex-[1.2]">
					<div class="split-media split-materiel-clip split-bg-materiel">
						<div class="split-overlay"></div>
					</div>
					<div class="split-content">
						<h2 class="split-title">Équipements</h2>
					</div>
				</a>

				<a href="{{ path('club_index') }}" class="split-col split-chevauchement hover:flex-[1.2]">
					<div class="split-separator"></div>
					<div class="split-media split-club-clip split-bg-club">
						<div class="split-overlay"></div>
					</div>
					<div class="split-content">
						<h2 class="split-title">Les clubs</h2>
					</div>
				</a>

				{% if is_granted('ROLE_ADMIN') %}
					<a href="{{ path('user_index') }}" class="split-col split-chevauchement hover:flex-[1.2]">
						<div class="split-separator"></div>
						<div class="split-media split-club-clip split-bg-admin">
							<div class="split-overlay"></div>
						</div>
						<div class="split-content">
							<h2 class="split-title">Gestion des utilisateurs</h2>
						</div>
					</a>
				{% endif %}
			</div>
		</section>
	</div>
{% endblock %}

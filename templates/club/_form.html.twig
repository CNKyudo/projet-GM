{{ form_start(form, { attr: { class: 'space-y-8' } }) }}

  {% if form.vars.errors|length %}
    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      {{ form_errors(form) }}
    </div>
  {% endif %}

  <section class="space-y-4">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.name.vars.label }}
        </label>
        {{ form_widget(form.name, {
          attr: {
            class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none placeholder:text-kyudo-gm-grey focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue'
          }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.name) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Région</label>
        {{ form_widget(form.region, {
          attr: {
            class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue'
          }
        }) }}
        <p class="mt-2 text-xs text-kyudo-gm-grey">Optionnel - région (CTK) à laquelle ce club est rattaché.</p>
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.region) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Président</label>
        {{ form_widget(form.president, {
          attr: {
            class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue'
          }
        }) }}
        <p class="mt-2 text-xs text-">Optionnel - sélectionnez un président si connu.</p>
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.president) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Gestionnaire matériel</label>
        {{ form_widget(form.equipmentManager, {
          attr: {
            class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue'
          }
        }) }}
        <p class="mt-2 text-xs text-">Optionnel - responsable de la gestion du matériel du club.</p>
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.equipmentManager) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.email.vars.label }}
        </label>
        {{ form_widget(form.email, {
          attr: {
            class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none placeholder:text-kyudo-gm-grey focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue'
          }
        }) }}
        <p class="mt-2 text-xs text-">Optionnel - email de contact du club.</p>
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.email) }}</div>
      </div>
    </div>
  </section>

  <section class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-gm-light-grey p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-sm font-semibold text-kyudo-gm-dark">Adresse</h2>
        <p class="mt-1 text-sm text-kyudo-gm-grey">Optionnel - utile pour localiser le dojo.</p>
      </div>
      <span class="rounded-full bg-kyudo-washed-blue px-3 py-1 text-xs font-medium text-(--color-kyudo-white)">
        Optionnel
      </span>
    </div>

    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      {% if form.address.city is defined %}
        <div>
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Ville</label>
          {{ form_widget(form.address.city, { attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' } }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.address.city) }}</div>
        </div>
      {% endif %}

      {% if form.address.country is defined %}
        <div>
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Pays</label>
          {{ form_widget(form.address.country, { attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' } }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.address.country) }}</div>
        </div>
      {% endif %}

      {% if form.address.streetAddress is defined %}
        <div>
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Rue</label>
          {{ form_widget(form.address.streetAddress, { attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' } }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.address.streetAddress) }}</div>
        </div>
      {% endif %}

      {% if form.address.postalCode is defined %}
        <div>
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">Code postal</label>
          {{ form_widget(form.address.postalCode, { attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' } }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.address.postalCode) }}</div>
        </div>
      {% endif %}

      {{ form_rest(form.address) }}
    </div>
  </section>

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-between">
    <a href="{{ cancel_path|default(path('club_index')) }}" class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)" data-history-back>
      Annuler
    </a>

    <button type="submit" class="cursor-pointer inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-5 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue">
      {{ submit_label|default('Enregistrer') }}
    </button>
  </div>

{{ form_end(form) }}

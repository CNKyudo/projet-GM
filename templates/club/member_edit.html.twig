{% extends 'base.html.twig' %}

{% block title %}Modifier le membre{% endblock %}

{% block body %}
	<div class="h-screen-with-navbar bg-kyudo-club pt-16 pb-10 px-4 sm:px-6">
		<div class="mx-auto max-w-2xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

			<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
				<div>
					<div class="text-sm font-medium text-kyudo-gm-grey">Membre du club</div>
					<h1 class="mt-1 text-2xl font-semibold tracking-tight text-kyudo-gm-dark">
						Modifier : {{ clubMember.fullName }}
					</h1>
					<p class="mt-1 text-kyudo-gm-grey">
						Club : {{ club.name }}
					</p>
				</div>

				<div>
					<a href="{{ path('club_show', {'id': club.id}) }}"
					   class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)">
						Retour
					</a>
				</div>
			</div>

			{% if clubMember.isRegistered %}
				<div class="mt-4 rounded-2xl bg-blue-50 border border-blue-200 p-4 text-sm text-blue-800">
					Ce membre est lié au compte utilisateur <strong>{{ clubMember.user.fullName }}</strong> ({{ clubMember.user.email }}).
				</div>
			{% endif %}

			<div class="mt-6">
				{{ form_start(form) }}
				<div class="grid gap-4 sm:grid-cols-2">
					<div>
						{{ form_row(form.firstName, {
							attr: { 'class': 'block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue' }
						}) }}
					</div>
					<div>
						{{ form_row(form.lastName, {
							attr: { 'class': 'block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue' }
						}) }}
					</div>
					<div>
						{{ form_row(form.email, {
							attr: { 'class': 'block w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue' }
						}) }}
					</div>
				</div>
				<div class="mt-6 flex gap-3">
					<button type="submit"
					        class="inline-flex items-center rounded-2xl bg-kyudo-blue px-5 py-2.5 text-sm font-medium text-(--color-kyudo-white) hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue">
						Enregistrer
					</button>
					<a href="{{ path('club_show', {'id': club.id}) }}"
					   class="inline-flex items-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-5 py-2.5 text-sm font-medium text-kyudo-gm-dark hover:bg-kyudo-gm-light-grey">
						Annuler
					</a>
				</div>
				{{ form_end(form) }}
			</div>

		</div>
	</div>
{% endblock %}

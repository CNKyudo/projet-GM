{% extends 'base.html.twig' %}

{% block title %}Détails du club
{% endblock %}

{% block body %}
	{% set requestedReturnTo = app.request.query.get('return_to') %}
	{% set backHref = requestedReturnTo and requestedReturnTo starts with '/' ? requestedReturnTo : path('club_index') %}
	<div class="h-screen-with-navbar bg-kyudo-club pt-16 pb-10 px-4 sm:px-6">
		<div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

			<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
				<div>
					<div class="text-sm font-medium text-">Club</div>
					<h1 class="mt-1 text-3xl font-semibold tracking-tight text-kyudo-gm-dark">
						{{ club.name }}
					</h1>
					<p class="mt-1 text-kyudo-gm-grey">
						Informations du club de Kyudo.
					</p>
				</div>

				<div class="flex flex-wrap gap-2">
					<a href="{{ backHref }}" class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)" data-history-back>
						Retour
					</a>

					<a href="{{ path('club_edit', {'id': club.id}) }}" class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue">
						Modifier
					</a>
				</div>
			</div>

			<div class="mt-8 grid gap-6 lg:grid-cols-3">
				<section class="lg:col-span-2 rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm">
					<h2 class="text-base font-semibold text-kyudo-gm-dark">Détails</h2>

					<dl class="mt-4 grid gap-4 sm:grid-cols-2">
						<div class="rounded-2xl bg-kyudo-gm-light-grey p-4">
							<dt class="text-xs font-medium text-">ID</dt>
							<dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">{{ club.id }}</dd>
						</div>

						<div class="rounded-2xl bg-kyudo-gm-light-grey p-4">
							<dt class="text-xs font-medium text-">Président</dt>
							<dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
								{{ club.president ?: '-' }}
							</dd>
						</div>

						<div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
							<dt class="text-xs font-medium text-">Email</dt>
							<dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
								{% if club.email %}
									<a class="text-blue-700 hover:underline" href="mailto:{{ club.email }}">{{ club.email }}</a>
								{% else %}
									<span class="text-">-</span>
								{% endif %}
							</dd>
						</div>
					</dl>
				</section>

				<aside class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm">
					<h2 class="text-base font-semibold text-kyudo-gm-dark">Adresse</h2>

					<div class="mt-4 rounded-2xl bg-kyudo-gm-light-grey p-4 text-sm text-kyudo-gm-dark">
						{% if club.address %}
							<div class="whitespace-pre-line leading-6">{{ club.address }}</div>
						{% else %}
							<div class="text-">-</div>
						{% endif %}
					</div>
				</aside>
			</div>

		</div>
	</div>
{% endblock %}

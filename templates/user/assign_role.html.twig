{% extends 'base.html.twig' %}

{% block title %}Attribuer un rôle
{% endblock %}

{% block body %}
	{% set defaultFieldClass = 'block w-full rounded-xl border border-gray-300 px-3 py-2 focus:border-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue' %}
	{% set invalidFieldClass = 'block w-full rounded-xl border border-red-300 bg-red-50/40 px-3 py-2 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500' %}

	{# Rôles nécessitant un club ou des régions (utilisés par le Stimulus controller) #}
	{% set rolesNeedingClub    = ['ROLE_CLUB_PRESIDENT', 'ROLE_EQUIPMENT_MANAGER_CLUB'] %}
	{% set rolesNeedingRegions = ['ROLE_EQUIPMENT_MANAGER_CTK'] %}

	{# Valeur du rôle actuel du formulaire (pour déterminer l'état initial) #}
	{% set currentRoleValue = form.newRole.vars.value %}

	<div class="h-screen-with-navbar bg-kyudo-club px-4 pb-10 pt-16 sm:px-6">
		<div class="mx-auto max-w-5xl rounded-[32px] bg-kyudo-white/95 p-6 shadow-2xl ring-1 ring-black/5 backdrop-blur sm:p-8 md:p-10">
			<div class="grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">

				<section
					class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm"
					data-controller="role-assign"
				>
					<h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark">Attribuer un rôle</h1>
					<p class="mt-3 max-w-2xl text-sm leading-6 text-kyudo-gm-grey">
						Définissez le rôle de
						<span class="font-semibold text-kyudo-gm-dark">{{ targetUser.fullName }}</span>
						dans l'application. L'ancien rôle sera remplacé automatiquement.
					</p>

					<div class="mt-8 max-w-2xl space-y-5">
						{{ form_start(form) }}

						{% if form.vars.errors|length %}
							{% include 'partials/_alert.html.twig' with {
								type: 'error',
								title: 'Le rôle ne peut pas être enregistré pour le moment.',
								errors: form.vars.errors,
								class: 'mb-5'
							} only %}
						{% endif %}

						{# Rôle #}
						<div>
							<label for="{{ form.newRole.vars.id }}" class="mb-1 block text-sm font-medium text-kyudo-gm-grey">
								{{ form.newRole.vars.label }}
							</label>
							{{ form_widget(form.newRole, {
								attr: {
									class: (form.newRole.vars.errors|length ? invalidFieldClass : defaultFieldClass),
									'data-role-assign-target': 'roleSelect',
									'data-action': 'change->role-assign#update'
								}
							}) }}
							{% if form.newRole.vars.errors|length %}
								{% include 'partials/_alert.html.twig' with {
									type: 'error',
									label: 'Champ invalide',
									errors: form.newRole.vars.errors,
									class: 'mt-3'
								} only %}
							{% endif %}
						</div>

						{# Club — ROLE_CLUB_PRESIDENT et ROLE_EQUIPMENT_MANAGER_CLUB #}
						<div
							data-role-assign-target="clubField"
							{% if currentRoleValue not in rolesNeedingClub %}hidden{% endif %}
						>
							<label for="{{ form.club.vars.id }}" class="mb-1 block text-sm font-medium text-kyudo-gm-grey">
								{{ form.club.vars.label }}
							</label>
							{{ form_widget(form.club, {
								attr: {
									class: form.club.vars.errors|length ? invalidFieldClass : defaultFieldClass,
									disabled: currentRoleValue not in rolesNeedingClub
								}
							}) }}
							{% if form.club.vars.errors|length %}
								{% include 'partials/_alert.html.twig' with {
									type: 'error',
									label: 'Champ invalide',
									errors: form.club.vars.errors,
									class: 'mt-3'
								} only %}
							{% endif %}
						</div>

						{# Régions gérées — ROLE_EQUIPMENT_MANAGER_CTK #}
						<div
							data-role-assign-target="regionsField"
							{% if currentRoleValue not in rolesNeedingRegions %}hidden{% endif %}
						>
							<label for="{{ form.managedRegions.vars.id }}" class="mb-1 block text-sm font-medium text-kyudo-gm-grey">
								{{ form.managedRegions.vars.label }}
							</label>
							{{ form_widget(form.managedRegions, {
								attr: {
									class: (form.managedRegions.vars.errors|length ? invalidFieldClass : defaultFieldClass) ~ ' min-h-[7rem]',
									disabled: currentRoleValue not in rolesNeedingRegions
								}
							}) }}
							<p class="mt-1 text-xs text-kyudo-gm-grey">Maintenez Ctrl (ou Cmd) pour sélectionner plusieurs régions.</p>
							{% if form.managedRegions.vars.errors|length %}
								{% include 'partials/_alert.html.twig' with {
									type: 'error',
									label: 'Champ invalide',
									errors: form.managedRegions.vars.errors,
									class: 'mt-3'
								} only %}
							{% endif %}
						</div>

						<div class="flex flex-col gap-3 sm:flex-row">
							<button type="submit" class="btn btn-primary">Enregistrer</button>
							<a class="btn btn-secondary" data-history-back href="{{ path('user_index') }}">Retour à la liste</a>
						</div>

						{{ form_end(form) }}
					</div>
				</section>

				<aside class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-gm-light-grey p-6 shadow-sm">
					<h2 class="text-xl font-semibold text-kyudo-gm-dark">Résumé utilisateur</h2>

					<div class="mt-4 rounded-2xl bg-kyudo-white p-4 shadow-sm">
						<p class="text-sm font-medium text-kyudo-gm-grey">Compte</p>
						<p class="mt-2 break-all text-base font-semibold text-kyudo-gm-dark">{{ targetUser.email }}</p>
						<p class="mt-1 text-sm text-kyudo-gm-grey">ID #{{ targetUser.id }}</p>
					</div>

					<div class="mt-4 rounded-2xl bg-kyudo-white p-4 shadow-sm">
						<p class="text-sm font-medium text-kyudo-gm-grey">Rôle actuel</p>
						<div class="mt-3 flex flex-wrap gap-2">
							{% for roleLabel in roleLabels %}
								<span class="rounded-full bg-kyudo-washed-blue px-3 py-1 text-xs font-semibold text-white">{{ roleLabel }}</span>
							{% else %}
								<span class="text-sm text-kyudo-gm-grey">Aucun rôle</span>
							{% endfor %}
						</div>
					</div>

					<div class="mt-4 rounded-2xl bg-kyudo-white p-4 shadow-sm">
						<p class="text-sm font-medium text-kyudo-gm-grey">Club (président)</p>
						<p class="mt-2 text-base font-semibold text-kyudo-gm-dark">
							{{ targetUser.clubWhichImPresidentOf ? targetUser.clubWhichImPresidentOf.name : 'Aucun' }}
						</p>
					</div>

					<div class="mt-4 rounded-2xl bg-kyudo-white p-4 shadow-sm">
						<p class="text-sm font-medium text-kyudo-gm-grey">Club (gestionnaire matériel)</p>
						<p class="mt-2 text-base font-semibold text-kyudo-gm-dark">
							{{ targetUser.clubWhereImEquipmentManager ? targetUser.clubWhereImEquipmentManager.name : 'Aucun' }}
						</p>
					</div>

					<div class="mt-4 rounded-2xl bg-kyudo-white p-4 shadow-sm">
						<p class="text-sm font-medium text-kyudo-gm-grey">Régions gérées</p>
						{% if targetUser.managedRegions|length %}
							<ul class="mt-2 space-y-1">
								{% for region in targetUser.managedRegions %}
									<li class="text-sm font-semibold text-kyudo-gm-dark">{{ region.name }}</li>
								{% endfor %}
							</ul>
						{% else %}
							<p class="mt-2 text-sm text-kyudo-gm-dark">Aucune</p>
						{% endif %}
					</div>

					{# Rôles assignables — info pour l'utilisateur connecté #}
					<div class="mt-4 rounded-2xl bg-kyudo-white p-4 shadow-sm">
						<p class="text-sm font-medium text-kyudo-gm-grey">Rôles que vous pouvez attribuer</p>
						<div class="mt-3 flex flex-wrap gap-2">
							{% for role in assignableRoles %}
								<span class="rounded-full bg-kyudo-gm-light-grey px-3 py-1 text-xs font-semibold text-kyudo-gm-dark">{{ role.label() }}</span>
							{% endfor %}
						</div>
					</div>
				</aside>

			</div>
		</div>
	</div>
{% endblock %}

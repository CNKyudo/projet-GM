{% extends 'base.html.twig' %}

{% block title %}Modifier mon mot de passe{% endblock %}

{% block body %}
    {% set defaultFieldClass = 'block w-full rounded-xl border border-gray-300 px-3 py-2 focus:border-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue' %}
    {% set invalidFieldClass = 'block w-full rounded-xl border border-red-300 bg-red-50/40 px-3 py-2 focus:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-500' %}

    <div class="h-screen-with-navbar bg-kyudo-club px-4 pb-10 pt-16 sm:px-6">
        <div class="mx-auto max-w-5xl rounded-[32px] bg-white/95 p-6 shadow-2xl ring-1 ring-black/5 backdrop-blur sm:p-8 md:p-10">
            <div class="grid gap-6 lg:grid-cols-[1.3fr_0.9fr]">
                <section class="rounded-3xl border border-kyudo-gm-light-grey bg-white p-6 shadow-sm">
                    <h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark">Modifier mon mot de passe</h1>
                    <p class="mt-3 max-w-2xl text-sm leading-6 text-gray-600">
                        Confirmez votre mot de passe actuel, puis saisissez un nouveau mot de passe robuste pour votre compte.
                    </p>

                    <div class="mt-8 max-w-2xl">
                        {{ form_start(form) }}

                            {% if form.vars.errors|length %}
                                {% include 'partials/_alert.html.twig' with {
                                    type: 'error',
                                    title: 'La mise a jour ne peut pas encore etre enregistree.',
                                    errors: form.vars.errors,
                                    class: 'mb-5'
                                } only %}
                            {% endif %}

                            {% if form.plainPassword.vars.errors|length %}
                                {% include 'partials/_alert.html.twig' with {
                                    type: 'warning',
                                    title: 'Le nouveau mot de passe doit etre corrige.',
                                    errors: form.plainPassword.vars.errors,
                                    class: 'mb-5'
                                } only %}
                            {% endif %}

                            <div class="space-y-5">
                                <div>
                                    <label for="{{ form.currentPassword.vars.id }}" class="mb-1 block text-sm font-medium text-gray-700">
                                        {{ form.currentPassword.vars.label|default('Mot de passe actuel') }}
                                    </label>
                                    {{ form_widget(form.currentPassword, {
                                        attr: {
                                            class: form.currentPassword.vars.errors|length ? invalidFieldClass : defaultFieldClass
                                        }
                                    }) }}
                                    {% if form.currentPassword.vars.errors|length %}
                                        {% include 'partials/_alert.html.twig' with {
                                            type: 'error',
                                            label: 'Champ invalide',
                                            errors: form.currentPassword.vars.errors,
                                            class: 'mt-3'
                                        } only %}
                                    {% endif %}
                                </div>

                                <div>
                                    <label for="{{ form.plainPassword.first.vars.id }}" class="mb-1 block text-sm font-medium text-gray-700">
                                        {{ form.plainPassword.first.vars.label|default('Nouveau mot de passe') }}
                                    </label>
                                    {{ form_widget(form.plainPassword.first, {
                                        attr: {
                                            class: (form.plainPassword.first.vars.errors|length or form.plainPassword.vars.errors|length) ? invalidFieldClass : defaultFieldClass
                                        }
                                    }) }}
                                    {% if form.plainPassword.first.vars.errors|length %}
                                        {% include 'partials/_alert.html.twig' with {
                                            type: 'error',
                                            label: 'Champ invalide',
                                            errors: form.plainPassword.first.vars.errors,
                                            class: 'mt-3'
                                        } only %}
                                    {% endif %}
                                </div>

                                <div>
                                    <label for="{{ form.plainPassword.second.vars.id }}" class="mb-1 block text-sm font-medium text-gray-700">
                                        {{ form.plainPassword.second.vars.label|default('Confirmation du mot de passe') }}
                                    </label>
                                    {{ form_widget(form.plainPassword.second, {
                                        attr: {
                                            class: (form.plainPassword.second.vars.errors|length or form.plainPassword.vars.errors|length) ? invalidFieldClass : defaultFieldClass
                                        }
                                    }) }}
                                    {% if form.plainPassword.second.vars.errors|length %}
                                        {% include 'partials/_alert.html.twig' with {
                                            type: 'error',
                                            label: 'Champ invalide',
                                            errors: form.plainPassword.second.vars.errors,
                                            class: 'mt-3'
                                        } only %}
                                    {% endif %}
                                </div>
                            </div>

                            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                                <button type="submit" class="btn btn-primary">Enregistrer</button>
                                <a class="btn btn-secondary" href="{{ path('user_profile') }}">Retour au profil</a>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </section>

                <aside class="rounded-3xl border border-kyudo-gm-light-grey bg-slate-50 p-6 shadow-sm">
                    <h2 class="text-xl font-semibold text-kyudo-gm-dark">Conseils</h2>
                    <div class="mt-4 rounded-2xl bg-white p-4 shadow-sm">
                        <p class="text-sm font-medium text-gray-500">Bonnes pratiques</p>
                        <ul class="mt-3 space-y-2 text-sm leading-6 text-gray-600">
                            <li>Utilisez une phrase de passe longue.</li>
                            <li>Evitez de reutiliser un mot de passe deja utilise ailleurs.</li>
                            <li>Conservez votre nouveau mot de passe dans un gestionnaire securise.</li>
                        </ul>
                    </div>

                    <div class="mt-5 flex flex-col gap-3">
                        <a class="rounded-2xl border border-gray-300 px-4 py-3 text-sm font-medium text-gray-700 transition hover:border-kyudo-washed-blue hover:bg-kyudo-washed-blue hover:text-white" href="{{ path('user_profile_edit') }}">
                            Modifier mon email
                        </a>
                        <a class="rounded-2xl border border-gray-300 px-4 py-3 text-sm font-medium text-gray-700 transition hover:border-kyudo-gm-dark hover:bg-kyudo-gm-dark hover:text-white" href="{{ path('user_profile') }}">
                            Revenir au profil
                        </a>
                    </div>
                </aside>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Gestion des utilisateurs
{% endblock %}

{% block body %}
	<div class="h-screen-with-navbar bg-kyudo-club px-4 pb-10 pt-16 sm:px-6">
		<div class="mx-auto max-w-7xl rounded-[32px] bg-kyudo-white/95 p-6 shadow-2xl ring-1 ring-black/5 backdrop-blur sm:p-8 md:p-10">
			<div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
				<div class="max-w-2xl">
					<h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark sm:text-4xl">Gestion des utilisateurs</h1>
					<p class="mt-3 text-sm leading-6 text-kyudo-gm-grey sm:text-base">
						Administrez les comptes, visualisez les rôles attribués et rattachez un utilisateur à un club depuis une interface cohérente avec le reste de l'espace compte.
					</p>
				</div>

				<div class="flex flex-col gap-3 sm:flex-row sm:items-center">
					<div class="rounded-2xl bg-kyudo-gm-light-grey px-4 py-3 text-sm font-medium text-kyudo-gm-grey">
						{{ users|length }}
						utilisateur{{ users|length > 1 ? 's' : '' }}
					</div>
					<a class="btn btn-secondary" data-history-back href="{{ path('user_profile') }}">Retour au profil</a>
				</div>
			</div>

			<div class="mt-8 overflow-hidden rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white shadow-sm">
				<div class="overflow-x-auto">
					<table class="min-w-full divide-y divide-kyudo-gm-light-grey">
						<thead class="bg-kyudo-gm-light-grey">
							<tr class="text-left text-sm font-semibold text-kyudo-gm-grey">
								<th class="px-5 py-4">Utilisateur</th>
								<th class="px-5 py-4">Rôles</th>
								<th class="px-5 py-4">Club</th>
								<th class="px-5 py-4 text-right">Actions</th>
							</tr>
						</thead>
						<tbody class="divide-y divide-kyudo-gm-light-grey">
							{% for user in users %}
								{% set currentRoleLabels = roleLabelsByUserId[user.id]|default([]) %}
								<tr class="align-top">
									<td class="px-5 py-4">
										<div class="font-semibold text-kyudo-gm-dark">{{ user.email }}</div>
										<div class="mt-1 text-sm text-kyudo-gm-grey">Compte #{{ user.id }}</div>
									</td>
									<td class="px-5 py-4">
										<div class="flex flex-wrap gap-2">
											{% for roleLabel in currentRoleLabels %}
												<span class="rounded-full bg-kyudo-washed-blue px-3 py-1 text-xs font-semibold text-white">{{ roleLabel }}</span>
											{% else %}
												<span class="text-sm text-kyudo-gm-grey">Aucun rôle</span>
											{% endfor %}
										</div>
									</td>
									<td class="px-5 py-4">
										{% if user.clubWhichImPresidentOf %}
											<div class="rounded-2xl bg-kyudo-gm-light-grey p-3">
												<div class="font-medium text-kyudo-gm-dark">{{ user.clubWhichImPresidentOf.name }}</div>
												<div class="mt-1 text-sm text-kyudo-gm-grey">Président du club</div>
											</div>
										{% else %}
											<span class="text-sm text-kyudo-gm-grey">Aucun club attribué</span>
										{% endif %}
									</td>
									<td class="px-5 py-4">
										<div class="flex justify-end">
											<a class="btn btn-primary" href="{{ path('user_assign_club', {'id': user.id}) }}">
												Attribuer un club
											</a>
										</div>
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="4" class="px-5 py-10 text-center text-sm text-kyudo-gm-grey">
										Aucun utilisateur trouvé.
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

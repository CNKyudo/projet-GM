{% extends 'base.html.twig' %}

{% block title %}Email de réinitialisation envoyé
{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
	<div class="flex min-h-screen flex-col bg-kyudo-white md:flex-row">
		<div id="login_display" class="absolute inset-0 bg-kyudo-login bg-cover bg-center bg-kyudo-white md:static md:flex-2">
			<div class="absolute inset-0 bg-black/40 bg-kyudo-login md:hidden"></div>
		</div>

		<div id="login_form" class="relative z-10 flex min-h-screen items-center justify-center p-6 md:min-h-0 md:flex-1 md:p-8 md:bg-kyudo-royal-blue">
			<div class="w-full max-w-md">
				<a href="{{ path('app_login') }}">
					<img class="relative mt-6 block w-full max-w-sm rounded-xl md:hidden" src="{{ asset('pictures/FRANCE_KYUDO_LOGOTYPE_RVB_PRINCIPAL BLEU.png') }}" alt="France Kyudo">
					<img class="relative mt-6 hidden w-full max-w-sm rounded-xl md:block" src="{{ asset('pictures/FRANCE_KYUDO_LOGOTYPE_RVB_PRINCIPAL BLANC.png') }}" alt="France Kyudo">
				</a>

				<div class="relative mt-3 rounded-[32px] bg-kyudo-white/95 p-6 shadow-2xl ring-1 ring-black/5 backdrop-blur sm:p-8">
					<h1 class="text-2xl font-bold text-center text-kyudo-royal-blue">Email envoyé</h1>
					<p class="mt-3 text-center text-sm leading-6 text-kyudo-gm-grey">
						Si un compte existe pour cette adresse, un message de réinitialisation vient d'être envoyé.
					</p>

					<div class="mt-6 rounded-2xl bg-kyudo-gm-light-grey p-4 text-sm leading-6 text-kyudo-gm-grey">
						<p>
							Ce lien expirera dans
							{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
						</p>
						<p class="mt-3">
							Si vous ne voyez rien arriver, regardez dans les spams puis recommencez la demande si besoin.
						</p>
					</div>

					<div class="mt-6 flex flex-col gap-3">
						<a href="{{ path('app_forgot_password_request') }}" class="btn btn-primary w-full">
							Réessayer
						</a>
						<a href="{{ path('app_login') }}" class="btn btn-secondary w-full" data-history-back>
							Retour à la connexion
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

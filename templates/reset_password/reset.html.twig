{% extends 'base.html.twig' %}

{% block title %}Reinitialisez votre mot de passe{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
    {% set defaultFieldClass = 'block w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue focus:border-kyudo-royal-blue' %}
    {% set invalidFieldClass = 'block w-full rounded-xl border border-red-300 bg-red-50/40 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500' %}

    <div class="flex min-h-screen flex-col bg-kyudo-white md:flex-row">
        <div id="login_display" class="absolute inset-0 bg-kyudo-login bg-cover bg-center bg-kyudo-white md:static md:flex-2">
            <div class="absolute inset-0 bg-black/40 bg-kyudo-login md:hidden"></div>
        </div>

        <div id="login_form" class="relative z-10 flex min-h-screen items-center justify-center p-6 md:min-h-0 md:flex-1 md:p-8 md:bg-kyudo-royal-blue">
            <div class="w-full max-w-md">
                <a href="{{ path('app_login') }}">
                    <img class="relative mt-6 block w-full max-w-sm rounded-xl md:hidden" src="{{ asset('pictures/FRANCE_KYUDO_LOGOTYPE_RVB_PRINCIPAL BLEU.png') }}" alt="France Kyudo">
                    <img class="relative mt-6 hidden w-full max-w-sm rounded-xl md:block" src="{{ asset('pictures/FRANCE_KYUDO_LOGOTYPE_RVB_PRINCIPAL BLANC.png') }}" alt="France Kyudo">
                </a>

                <div class="relative mt-3 rounded-[32px] bg-white/95 p-6 shadow-2xl ring-1 ring-black/5 backdrop-blur sm:p-8">
                    <h1 class="text-2xl font-bold text-center text-kyudo-royal-blue">Nouveau mot de passe</h1>
                    <p class="mt-3 text-center text-sm leading-6 text-gray-600">
                        Definissez un nouveau mot de passe fort pour finaliser la reinitialisation de votre compte.
                    </p>

                    <div class="mt-6 rounded-2xl bg-slate-50 p-4 text-sm leading-6 text-gray-600">
                        Choisissez un mot de passe long, unique et difficile a deviner.
                    </div>

                    <div class="mt-6">
                        {{ form_start(resetForm) }}
                            {% if resetForm.vars.errors|length %}
                                {% include 'partials/_alert.html.twig' with {
                                    type: 'error',
                                    title: 'Le mot de passe ne peut pas etre enregistre.',
                                    errors: resetForm.vars.errors,
                                    class: 'mb-5'
                                } only %}
                            {% endif %}

                            <div>
                                <label for="{{ resetForm.plainPassword.vars.id }}" class="mb-1 block text-sm font-medium text-gray-700">
                                    {{ resetForm.plainPassword.vars.label|default('Nouveau mot de passe') }}
                                </label>
                                {{ form_widget(resetForm.plainPassword, {
                                    attr: {
                                        class: resetForm.plainPassword.vars.errors|length ? invalidFieldClass : defaultFieldClass
                                    }
                                }) }}
                                {% if resetForm.plainPassword.vars.errors|length %}
                                    {% include 'partials/_alert.html.twig' with {
                                        type: 'error',
                                        label: 'Champ invalide',
                                        errors: resetForm.plainPassword.vars.errors,
                                        class: 'mt-3'
                                    } only %}
                                {% endif %}
                            </div>

                            <div class="mt-6 flex flex-col gap-3">
                                <button class="w-full rounded-xl bg-kyudo-royal-blue px-4 py-3 font-semibold text-(--color-kyudo-white) shadow transition-colors duration-200 hover:bg-kyudo-blue focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue focus:ring-offset-2" type="submit">
                                    Reinitialiser le mot de passe
                                </button>
                                <a href="{{ path('app_login') }}" class="w-full rounded-xl bg-kyudo-gray px-4 py-3 text-center font-semibold text-kyudo-royal-blue shadow transition-colors duration-200 hover:bg-kyudo-royal-blue hover:text-(--color-kyudo-white)">
                                    Retour a la connexion
                                </a>
                            </div>
                        {{ form_end(resetForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Reinitialisation de mot de passe
{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
	{% set defaultFieldClass = 'block w-full rounded-xl border border-gray-300 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-kyudo-royal-blue focus:border-kyudo-royal-blue' %}
	{% set invalidFieldClass = 'block w-full rounded-xl border border-red-300 bg-red-50/40 px-3 py-2 focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-red-500' %}

	<div class="flex min-h-screen flex-col bg-kyudo-white md:flex-row">
		<div id="login_display" class="absolute inset-0 bg-kyudo-login bg-cover bg-center bg-kyudo-white md:static md:flex-2">
			<div class="absolute inset-0 bg-black/40 bg-kyudo-login md:hidden"></div>
		</div>

		<div id="login_form" class="relative z-10 flex min-h-screen items-center justify-center p-6 md:min-h-0 md:flex-1 md:p-8 md:bg-kyudo-royal-blue">
			<div class="w-full max-w-md">
				<a href="{{ path('app_login') }}">
					<img class="relative mt-6 block w-full max-w-sm rounded-xl md:hidden" src="{{ asset('pictures/FRANCE_KYUDO_LOGOTYPE_RVB_PRINCIPAL BLEU.png') }}" alt="France Kyudo">
					<img class="relative mt-6 hidden w-full max-w-sm rounded-xl md:block" src="{{ asset('pictures/FRANCE_KYUDO_LOGOTYPE_RVB_PRINCIPAL BLANC.png') }}" alt="France Kyudo">
				</a>

				<div class="relative mt-3 rounded-[32px] bg-kyudo-white/95 p-6 shadow-2xl ring-1 ring-black/5 backdrop-blur sm:p-8">
					<h1 class="text-2xl font-bold text-center text-kyudo-royal-blue">Mot de passe oublie</h1>
					<p class="mt-3 text-center text-sm leading-6 text-kyudo-gm-grey">
						Renseignez l'email associe a votre compte. Un lien de reinitialisation vous sera envoye.
					</p>

					<div class="mt-6 rounded-2xl bg-slate-50 p-4">
						<p class="text-sm font-medium text-kyudo-gm-grey">Besoin d'aide ?</p>
						<p class="mt-2 text-sm leading-6 text-kyudo-gm-grey">
							Si vous ne recevez rien, pensez a verifier vos spams ou a confirmer que l'adresse email saisie est bien celle utilisee lors de votre inscription.
						</p>
					</div>

					<div class="mt-6">
						{{ form_start(requestForm) }}
						{% if requestForm.vars.errors|length %}
							{% include 'partials/_alert.html.twig' with {
                                    type: 'error',
                                    title: 'La demande de reinitialisation ne peut pas etre envoyee.',
                                    errors: requestForm.vars.errors,
                                    class: 'mb-5'
                                } only %}
						{% endif %}

						<div>
							<label for="{{ requestForm.email.vars.id }}" class="mb-1 block text-sm font-medium text-kyudo-gm-grey">
								{{ requestForm.email.vars.label|default('Adresse email') }}
							</label>
							{{ form_widget(requestForm.email, {
                                    attr: {
                                        class: requestForm.email.vars.errors|length ? invalidFieldClass : defaultFieldClass
                                    }
                                }) }}
							{% if requestForm.email.vars.errors|length %}
								{% include 'partials/_alert.html.twig' with {
                                        type: 'error',
                                        label: 'Champ invalide',
                                        errors: requestForm.email.vars.errors,
                                        class: 'mt-3'
                                    } only %}
							{% endif %}
						</div>

						<div class="mt-6 flex flex-col gap-3">
								<button class="btn btn-primary w-full" type="submit">
									Envoyer le lien de reinitialisation
								</button>
								<a href="{{ path('app_login') }}" class="btn btn-secondary w-full">
									Retour a la connexion
								</a>
						</div>
						{{ form_end(requestForm) }}
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

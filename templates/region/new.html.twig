{% extends 'base.html.twig' %}

{% block title %}Nouvelle région{% endblock %}

{% block body %}
  <div class="h-screen-with-navbar bg-kyudo-club pt-16 pb-10 px-4 sm:px-6">
    <div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark">Créer une région</h1>
          <p class="mt-1 text-kyudo-gm-grey">Ajoutez une région (CTK) à la fédération.</p>
        </div>
      </div>

      <div class="px-8 py-8">
        {% include 'region/_form.html.twig' with {
          form: form,
          submit_label: 'Enregistrer',
          cancel_path: path('region_index')
        } %}
      </div>
    </div>
  </div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Régions{% endblock %}

{% block body %}
  <div class="h-screen-with-navbar bg-kyudo-club pt-16 pb-10 px-4 sm:px-6">
    <div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark">Régions (CTK)</h1>
          <p class="mt-1 text-kyudo-gm-grey">Répertoire des régions de la fédération.</p>
        </div>

        <a href="{{ path('region_new') }}" class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:ring-2 focus:ring-kyudo-washed-blue">
          + Ajouter une région
        </a>
      </div>

      <div class="mt-8 overflow-x-auto rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white shadow-sm">
        <table class="w-full text-left">
          <thead class="bg-kyudo-washed-blue text-sm text-(--color-kyudo-white)">
            <tr>
              <th class="px-5 py-4 font-medium">ID</th>
              <th class="px-5 py-4 font-medium">Nom</th>
              <th class="px-5 py-4 font-medium">Fédération</th>
              <th class="px-5 py-4 font-medium">Email</th>
              <th class="px-5 py-4 font-medium">Clubs</th>
              <th class="px-5 py-4 font-medium text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-kyudo-gm-light-grey text-sm">
            {% for region in regions %}
              <tr class="hover:bg-kyudo-gm-light-grey">
                <td class="px-5 py-4 text-kyudo-gm-grey">{{ region.id }}</td>
                <td class="px-5 py-4 font-semibold text-kyudo-gm-dark">{{ region.name }}</td>
                <td class="px-5 py-4 text-kyudo-gm-dark">{{ region.federation.name }}</td>
                <td class="px-5 py-4">
                  {% if region.email %}
                    <a class="text-kyudo-gm-dark hover:text-blue-700" href="mailto:{{ region.email }}">{{ region.email }}</a>
                  {% else %}
                    <span class="text-kyudo-gm-grey">-</span>
                  {% endif %}
                </td>
                <td class="px-5 py-4 text-kyudo-gm-dark">{{ region.clubs|length }}</td>
                <td class="px-5 py-4">
                  <div class="flex justify-end gap-2">
                    <a class="rounded-xl border border-kyudo-gm-light-grey bg-kyudo-white px-3 py-2 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)" href="{{ path('region_show', {'id': region.id}) }}">
                      Voir
                    </a>
                    <a class="rounded-xl border border-kyudo-gm-light-grey bg-kyudo-white px-3 py-2 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)" href="{{ path('region_edit', {'id': region.id}) }}">
                      Modifier
                    </a>
                    <form method="post" action="{{ path('region_delete', {'id': region.id}) }}" onsubmit="return confirm('Supprimer cette région ?')">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ region.id) }}">
                      <button type="submit" class="cursor-pointer rounded-xl border border-red-200 bg-kyudo-white px-3 py-2 font-medium text-red-600 hover:bg-red-50">
                        Supprimer
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="6" class="px-5 py-10 text-center text-kyudo-gm-dark">
                  Aucune région trouvée.
                  <div class="mt-3">
                    <a class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) hover:bg-kyudo-royal-blue" href="{{ path('region_new') }}">
                      + Ajouter une région
                    </a>
                  </div>
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="mt-6 flex justify-center">
        {{ knp_pagination_render(regions) }}
      </div>

    </div>
  </div>
{% endblock %}

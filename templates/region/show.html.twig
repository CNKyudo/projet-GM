{% extends 'base.html.twig' %}

{% block title %}Détails de la région{% endblock %}

{% block body %}
  <div class="h-screen-with-navbar bg-kyudo-club pt-16 pb-10 px-4 sm:px-6">
    <div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <div class="text-sm font-medium text-kyudo-gm-grey">Région</div>
          <h1 class="mt-1 text-3xl font-semibold tracking-tight text-kyudo-gm-dark">
            {{ region.name }}
          </h1>
          <p class="mt-1 text-kyudo-gm-grey">Informations de la région (CTK).</p>
        </div>

        <div class="flex flex-wrap gap-2">
          <a href="{{ path('region_index') }}" class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)" data-history-back>
            Retour
          </a>
          <a href="{{ path('region_edit', {'id': region.id}) }}" class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue">
            Modifier
          </a>
        </div>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        <section class="lg:col-span-2 rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm">
          <h2 class="text-base font-semibold text-kyudo-gm-dark">Détails</h2>

          <dl class="mt-4 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4">
              <dt class="text-xs font-medium text-kyudo-gm-grey">ID</dt>
              <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">{{ region.id }}</dd>
            </div>

            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4">
              <dt class="text-xs font-medium text-kyudo-gm-grey">Fédération</dt>
              <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">{{ region.federation.name }}</dd>
            </div>

            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
              <dt class="text-xs font-medium text-kyudo-gm-grey">Email</dt>
              <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                {% if region.email %}
                  <a class="text-blue-700 hover:underline" href="mailto:{{ region.email }}">{{ region.email }}</a>
                {% else %}
                  <span class="text-kyudo-gm-grey">-</span>
                {% endif %}
              </dd>
            </div>
          </dl>
        </section>

        <aside class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm">
          <h2 class="text-base font-semibold text-kyudo-gm-dark">Clubs rattachés</h2>

          <div class="mt-4 space-y-2">
            {% for club in region.clubs %}
              <a href="{{ path('club_show', {'id': club.id}) }}" class="block rounded-2xl bg-kyudo-gm-light-grey px-4 py-3 text-sm font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)">
                {{ club.name }}
              </a>
            {% else %}
              <p class="text-sm text-kyudo-gm-grey">Aucun club rattaché.</p>
            {% endfor %}
          </div>
        </aside>
      </div>

    </div>
  </div>
{% endblock %}

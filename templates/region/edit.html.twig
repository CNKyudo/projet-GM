{% extends 'base.html.twig' %}

{% block title %}Modifier la région{% endblock %}

{% block body %}
  <div class="h-screen-with-navbar bg-kyudo-club pt-16 pb-10 px-4 sm:px-6">
    <div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h1 class="text-3xl font-semibold tracking-tight text-kyudo-gm-dark">
            Modifier : {{ region.name }}
          </h1>
          <p class="mt-1 text-kyudo-gm-grey">Mettez à jour les informations de la région.</p>
        </div>

        <div class="flex flex-wrap gap-2">
          <a href="{{ path('region_show', {'id': region.id}) }}" class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)">
            Voir
          </a>
          <a href="{{ path('region_index') }}" class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)" data-history-back>
            Retour à la liste
          </a>
        </div>
      </div>

      <div class="mt-8">
        {% include 'region/_form.html.twig' with {
          form: form,
          submit_label: 'Enregistrer',
          cancel_path: path('region_show', {'id': region.id})
        } %}
      </div>
    </div>
  </div>
{% endblock %}

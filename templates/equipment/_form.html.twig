{# equipment/form.html.twig #}

{{ form_start(form, { attr: { class: 'space-y-8' } }) }}

  {% if form.vars.errors|length %}
    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      {{ form_errors(form) }}
    </div>
  {% endif %}

  <section class="space-y-4">
    <div class="grid gap-4 sm:grid-cols-2">

      {% if form.equipment_type is defined %}
        <div class="sm:col-span-2">
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.equipment_type.vars.label|default('Type d’équipement') }}
          </label>
          {{ form_widget(form.equipment_type, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue', 'data-equipment-type-selector': '1' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.equipment_type) }}</div>
        </div>
      {% endif %}

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.owner_club.vars.label|default('Propriétaire') }}
        </label>
        {{ form_widget(form.owner_club, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.owner_club) }}</div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.borrower_club.vars.label|default('Club emprunteur') }}
        </label>
        {{ form_widget(form.borrower_club, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <p class="mt-2 text-xs text-">Optionnel — si vide, l’équipement est considéré disponible.</p>
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.borrower_club) }}</div>
      </div>

      <div class="sm:col-span-2">
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.borrower_user.vars.label|default('Emprunté par (personne)') }}
        </label>
        {{ form_widget(form.borrower_user, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.borrower_user) }}</div>
      </div>
    </div>
  </section>

  {# Specific fields by type #}
  <section class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-gm-light-grey p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-sm font-semibold text-kyudo-gm-dark">Détails</h2>
        <p class="mt-1 text-sm text-kyudo-gm-grey">Champs spécifiques selon le type.</p>
      </div>
    </div>

    <div class="mt-5 grid gap-4 sm:grid-cols-2">

      <div id="glove_form_section"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'glove') or form.glove_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.glove_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.glove_form.nb_fingers.vars.label|default('Nombre de doigts') }}
          </label>
          {{ form_widget(form.glove_form.nb_fingers, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.glove_form.nb_fingers) }}</div>
        {% endif %}
      </div>

      <div id="yumi_form_section"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'yumi') or form.yumi_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.yumi_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yumi_form.material.vars.label|default('Matériau') }}
          </label>
          {{ form_widget(form.yumi_form.material, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yumi_form.material) }}</div>
        {% endif %}
      </div>

    </div>
  </section>

  {# render remaining hidden fields (csrf, etc.) #}
  {{ form_rest(form) }}

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-between">
    <a
      href="{{ path('equipment.index') }}"
      class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
    >
      Annuler
    </a>

    <button
      type="submit"
      class="cursor-pointer inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-5 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue"
    >
      Enregistrer
    </button>
  </div>

{{ form_end(form) }}

{% if form.equipment_type is defined %}
  <script>
    (function () {
      const typeField = document.getElementById('{{ form.equipment_type.vars.id }}');
      const gloveSection = document.getElementById('glove_form_section');
      const yumiSection = document.getElementById('yumi_form_section');

      if (!typeField) {
        return;
      }

      function setEnabled(section, enabled) {
        if (!section) {
          return;
        }

        section.classList.toggle('hidden', !enabled);
        section.classList.toggle('d-none', !enabled);
        section.querySelectorAll('input, select').forEach(function (element) {
          element.disabled = !enabled;
        });
      }

      function normalizeType() {
        const option = typeField.options[typeField.selectedIndex];
        const values = [
          typeField.value,
          option ? option.value : '',
          option ? option.textContent : '',
          option ? option.getAttribute('data-equipment-type') : '',
        ].map(function (value) {
          return String(value || '').toLowerCase();
        });

        if (values.some(function (value) { return value.includes('glove'); })) {
          return 'glove';
        }

        if (values.some(function (value) { return value.includes('yumi'); })) {
          return 'yumi';
        }

        return '';
      }

      function refreshSections() {
        const type = normalizeType();
        setEnabled(gloveSection, type === 'glove');
        setEnabled(yumiSection, type === 'yumi');
      }

      refreshSections();
      typeField.addEventListener('change', refreshSections);
      document.addEventListener('turbo:load', refreshSections);
    })();
  </script>
{% endif %}


{# equipment/form.html.twig #}

{{ form_start(form, { attr: { class: 'space-y-8', 'data-equipment-form-root': '1' } }) }}

  {% if form.vars.errors|length %}
    <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
      {{ form_errors(form) }}
    </div>
  {% endif %}

  <section class="space-y-4">
    <div class="grid gap-4 sm:grid-cols-2">

      {% if form.equipment_type is defined %}
        <div class="sm:col-span-2">
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.equipment_type.vars.label|default("Type d'équipement") }}
          </label>
          {{ form_widget(form.equipment_type, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue', 'data-equipment-type-selector': '1' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.equipment_type) }}</div>
        </div>
      {% endif %}

      {% if form.ownerFederation is defined %}
        <div>
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.ownerFederation.vars.label|default('Fédération propriétaire (national)') }}
          </label>
          {{ form_widget(form.ownerFederation, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.ownerFederation) }}</div>
        </div>
      {% endif %}

      {% if form.ownerRegion is defined %}
        <div>
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.ownerRegion.vars.label|default('Région propriétaire (régional)') }}
          </label>
          {{ form_widget(form.ownerRegion, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.ownerRegion) }}</div>
        </div>
      {% endif %}

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.ownerClub.vars.label|default('Club propriétaire') }}
        </label>
        {{ form_widget(form.ownerClub, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.ownerClub) }}</div>
      </div>

      <div class="sm:col-span-2">
        <p class="mb-2 text-sm font-semibold text-kyudo-gm-dark">Emprunteur</p>
        <p class="mb-3 text-xs text-kyudo-gm-grey">Optionnel — si les deux champs sont vides, l'équipement est considéré disponible.</p>
        <div class="grid gap-3 sm:grid-cols-2">
          <div>
            <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark" for="{{ form.borrowerClub.vars.id }}">
              {{ form.borrowerClub.vars.label|default('Club emprunteur') }}
            </label>
            {{ form_widget(form.borrowerClub, {
              attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
            }) }}
            <div class="mt-1 text-sm text-red-600">{{ form_errors(form.borrowerClub) }}</div>
          </div>
          <div>
            <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark" for="{{ form.borrowerMember.vars.id }}">
              {{ form.borrowerMember.vars.label|default('Membre emprunteur') }}
            </label>
            {{ form_widget(form.borrowerMember, {
              attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
            }) }}
            <div class="mt-1 text-sm text-red-600">{{ form_errors(form.borrowerMember) }}</div>
          </div>
        </div>
      </div>

      <div>
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.state.vars.label|trans({}, 'messages') }}
        </label>
        {{ form_widget(form.state, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue' }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.state) }}</div>
      </div>

      <div class="sm:col-span-2">
        <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
          {{ form.notes.vars.label|trans({}, 'messages') }}
        </label>
        {{ form_widget(form.notes, {
          attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 text-kyudo-gm-dark shadow-sm outline-none focus:border-kyudo-gm-light-grey focus:ring-2 focus:ring-kyudo-washed-blue', rows: 4 }
        }) }}
        <div class="mt-1 text-sm text-red-600">{{ form_errors(form.notes) }}</div>
      </div>

    </div>
  </section>

  <section class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-gm-light-grey p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-sm font-semibold text-kyudo-gm-dark">Détails</h2>
        <p class="mt-1 text-sm text-kyudo-gm-grey">Champs spécifiques selon le type.</p>
      </div>
    </div>

    <div class="mt-5 grid gap-4 sm:grid-cols-2">

      <div id="glove_form_section" data-equipment-form-section="glove"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'glove') or form.glove_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.glove_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.glove_form.nb_fingers.vars.label|default('Nombre de doigts') }}
          </label>
          {{ form_widget(form.glove_form.nb_fingers, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.glove_form.nb_fingers) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.glove_form.size.vars.label|default('Taille') }}
          </label>
          {{ form_widget(form.glove_form.size, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.glove_form.size) }}</div>
        {% endif %}
      </div>

      <div id="yumitate_form_section" data-equipment-form-section="yumitate"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'yumitate') or form.yumitate_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.yumitate_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yumitate_form.nb_bows.vars.label|default('Nombre d\'arcs') }}
          </label>
          {{ form_widget(form.yumitate_form.nb_bows, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yumitate_form.nb_bows) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yumitate_form.orientation.vars.label|default('Orientation') }}
          </label>
          {{ form_widget(form.yumitate_form.orientation, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yumitate_form.orientation) }}</div>
        {% endif %}
      </div>

      <div id="support_makiwara_form_section" data-equipment-form-section="support_makiwara"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'support_makiwara') or form.support_makiwara_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.support_makiwara_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.support_makiwara_form.height.vars.label|default('Hauteur (m)') }}
          </label>
          {{ form_widget(form.support_makiwara_form.height, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.support_makiwara_form.height) }}</div>
        {% endif %}
      </div>

      <div id="makiwara_form_section" data-equipment-form-section="makiwara"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'makiwara') or form.makiwara_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.makiwara_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.makiwara_form.material.vars.label|default('Matériau') }}
          </label>
          {{ form_widget(form.makiwara_form.material, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.makiwara_form.material) }}</div>
        {% endif %}
      </div>

      <div id="yumi_form_section" data-equipment-form-section="yumi"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'yumi') or form.yumi_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.yumi_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yumi_form.material.vars.label|default('Matériau') }}
          </label>
          {{ form_widget(form.yumi_form.material, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yumi_form.material) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yumi_form.strength.vars.label|default('Force') }}
          </label>
          {{ form_widget(form.yumi_form.strength, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yumi_form.strength) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yumi_form.yumiLength.vars.label|default('Taille') }}
          </label>
          {{ form_widget(form.yumi_form.yumiLength, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yumi_form.yumiLength) }}</div>
        {% endif %}
      </div>

      <div id="yatate_form_section" data-equipment-form-section="yatate"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'yatate') or form.yatate_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.yatate_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.yatate_form.nb_arrows.vars.label|default('Nombre de flèches') }}
          </label>
          {{ form_widget(form.yatate_form.nb_arrows, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.yatate_form.nb_arrows) }}</div>
        {% endif %}
      </div>

      <div id="maku_form_section" data-equipment-form-section="maku"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'maku') or form.maku_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.maku_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.maku_form.length.vars.label|default('Longueur (m)') }}
          </label>
          {{ form_widget(form.maku_form.length, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.maku_form.length) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.maku_form.height.vars.label|default('Hauteur (m)') }}
          </label>
          {{ form_widget(form.maku_form.height, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.maku_form.height) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.maku_form.material.vars.label|default('Matière') }}
          </label>
          {{ form_widget(form.maku_form.material, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.maku_form.material) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.maku_form.weight.vars.label|default('Poids (kg)') }}
          </label>
          {{ form_widget(form.maku_form.weight, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.maku_form.weight) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.maku_form.attachment.vars.label|default('Accroche') }}
          </label>
          {{ form_widget(form.maku_form.attachment, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.maku_form.attachment) }}</div>
        {% endif %}
      </div>

      <div id="etafoam_form_section" data-equipment-form-section="etafoam"
        {% if (form.equipment_type is defined and form.equipment_type.vars.value != 'etafoam') or form.etafoam_form is not defined %}
            class="hidden"
        {% endif %}
      >
        {% if form.etafoam_form is defined %}
          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.etafoam_form.length.vars.label|default('Longueur (cm)') }}
          </label>
          {{ form_widget(form.etafoam_form.length, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.etafoam_form.length) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.etafoam_form.width.vars.label|default('Largeur (cm)') }}
          </label>
          {{ form_widget(form.etafoam_form.width, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.etafoam_form.width) }}</div>

          <label class="mb-1 block text-sm font-medium text-kyudo-gm-dark">
            {{ form.etafoam_form.thickness.vars.label|default('Épaisseur (cm)') }}
          </label>
          {{ form_widget(form.etafoam_form.thickness, {
            attr: { class: 'w-full rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 shadow-sm outline-none focus:ring-2 focus:ring-kyudo-washed-blue' }
          }) }}
          <div class="mt-1 text-sm text-red-600">{{ form_errors(form.etafoam_form.thickness) }}</div>
        {% endif %}
      </div>

    </div>
  </section>

  {{ form_rest(form) }}

  <div class="flex flex-col-reverse gap-3 sm:flex-row sm:items-center sm:justify-between">
    <a
      href="{{ path('equipment.index') }}"
      data-history-back
      class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
    >
      Annuler
    </a>

    <button
      type="submit"
      class="cursor-pointer inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-5 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue"
    >
      Enregistrer
    </button>
  </div>

{{ form_end(form) }}

{% extends 'base.html.twig' %}

{% block title %}Détails de l'équipement{% endblock %}

{% block body %}
  <div class="h-screen-with-navbar bg-kyudo-equipment pt-16 pb-10 px-4 sm:px-6">
    <div class="mx-auto max-w-6xl rounded-3xl bg-kyudo-white shadow-xl p-5 sm:p-8 md:p-12">

      <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <div class="text-sm font-medium text-">Équipement</div>
          <h1 class="mt-1 text-3xl font-semibold tracking-tight text-kyudo-gm-dark">
            #{{ equipment.id }} - {{ equipment.typeName }}
          </h1>
          <p class="mt-1 text-kyudo-gm-grey">Propriétaire et emprunteur actuel.</p>
        </div>

        <div class="flex flex-wrap gap-2">
          <a
            href="{{ path('equipment.index') }}"
            data-history-back
            class="inline-flex items-center justify-center rounded-2xl border border-kyudo-gm-light-grey bg-kyudo-white px-4 py-2.5 font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
          >
            Retour
          </a>
          {% if is_granted('EDIT_EQUIPMENT', equipment) %}
            <a
              href="{{ path('equipment.edit', {'id': equipment.id}) }}"
              class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2.5 font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue focus:outline-none focus:ring-2 focus:ring-kyudo-washed-blue"
            >
              Modifier
            </a>
          {% endif %}
        </div>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        <section class="lg:col-span-2 rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm">
          <h2 class="text-base font-semibold text-kyudo-gm-dark">Détails</h2>

          <dl class="mt-4 grid gap-4 sm:grid-cols-2">
            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4">
              <dt class="text-xs font-medium text-">ID</dt>
              <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">{{ equipment.id }}</dd>
            </div>

            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4">
              <dt class="text-xs font-medium text-">Type</dt>
              <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">{{ equipment.typeName }}</dd>
            </div>

            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
              <dt class="text-xs font-medium text-">Propriétaire</dt>
              <dd class="mt-1 flex flex-wrap items-center gap-2">
                {% set level = equipment.equipmentLevel.value %}
                {% if level == 'national' %}
                  <span class="inline-flex items-center rounded-full bg-purple-100 px-2 py-0.5 text-xs font-semibold text-purple-800">National</span>
                  <span class="text-sm font-semibold text-kyudo-gm-dark">- {{ equipment.ownerFederation ? equipment.ownerFederation.name : '-' }}</span>
                {% elseif level == 'regional' %}
                  <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-800">Régional</span>
                  <span class="text-sm font-semibold text-kyudo-gm-dark">- {{ equipment.ownerRegion ? equipment.ownerRegion.name : '-' }}</span>
                {% else %}
                  <span class="inline-flex items-center rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-800">Club</span>
                  <span class="text-sm font-semibold text-kyudo-gm-dark">- {{ equipment.ownerClub ? equipment.ownerClub.name : '-' }}</span>
                {% endif %}
              </dd>
            </div>

            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
              <dt class="text-xs font-medium text-">{{ 'equipment.state.label'|trans }}</dt>
              <dd class="mt-1">
                <span class="inline-flex items-center rounded-full
                   {% if equipment.state.value == constant('App\\Enum\\EquipmentState::NEW').value %}
                    bg-emerald-50 text-emerald-800
                  {% elseif equipment.state.value == constant('App\\Enum\\EquipmentState::USED').value %}
                    bg-amber-50 text-amber-800
                  {% elseif equipment.state.value == constant('App\\Enum\\EquipmentState::TO_REPAIR').value %}
                    bg-red-100 text-red-900
                  {% endif %}
                  px-3 py-1 text-xs font-medium">
                  {{ ('equipment.state.' ~ equipment.state.value)|trans }}
                </span>
              </dd>
            </div>

            {% if equipment.notes %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">{{ 'equipment.notes.label'|trans }}</dt>
                <dd class="mt-1 text-sm text-kyudo-gm-dark">{{ equipment.notes|nl2br }}</dd>
              </div>
            {% endif %}

            {% if equipment.typeName == 'glove' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Nombre de doigts</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.nbFingers is not null ? equipment.nbFingers : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Taille</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.size is not null ? equipment.size : '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'yumi' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Matériau</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.material ?: '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Force (kg)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.strength ?: '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Taille</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.yumiLength ? equipment.yumiLength.label|trans : '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'makiwara' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Matériau</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.material ? equipment.material.label|trans : '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'support_makiwara' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Hauteur (m)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.height is not null ? equipment.height : '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'yumitate' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Nombre d'arcs</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.nbBows is not null ? equipment.nbBows : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Orientation</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.orientation ? equipment.orientation.label|trans : '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'yatate' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Nombre de flèches</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.nbArrows is not null ? equipment.nbArrows : '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'maku' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Longueur (m)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.equipmentLength is not null ? equipment.equipmentLength : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Hauteur (m)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.height is not null ? equipment.height : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Matière</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.material ?: '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Poids (kg)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.weight is not null ? equipment.weight : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Accroche</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.attachment ?: '-' }}
                </dd>
              </div>
            {% elseif equipment.typeName == 'etafoam' %}
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Longueur (cm)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.equipmentLength is not null ? equipment.equipmentLength : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Largeur (cm)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.width is not null ? equipment.width : '-' }}
                </dd>
              </div>
              <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
                <dt class="text-xs font-medium text-">Épaisseur (cm)</dt>
                <dd class="mt-1 text-sm font-semibold text-kyudo-gm-dark">
                  {{ equipment.thickness is not null ? equipment.thickness : '-' }}
                </dd>
              </div>
            {% endif %}

            <div class="rounded-2xl bg-kyudo-gm-light-grey p-4 sm:col-span-2">
              <dt class="text-xs font-medium text-">Statut</dt>
              <dd class="mt-2">
                {% if equipment.borrowerClub %}
                  <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-800">
                    Prêté à <span class="font-semibold">{{ equipment.borrowerClub.name }}</span>
                  </span>
                {% elseif equipment.borrowerMember %}
                  <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-800">
                    Emprunté par <span class="font-semibold">{{ equipment.borrowerMember.fullName }}</span>
                  </span>
                {% else %}
                  <span class="inline-flex items-center rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-800">
                    Disponible
                  </span>
                {% endif %}
              </dd>
            </div>
          </dl>
        </section>

        <aside class="rounded-3xl border border-kyudo-gm-light-grey bg-kyudo-white p-6 shadow-sm">
          <h2 class="text-base font-semibold text-kyudo-gm-dark">Emprunteur</h2>

          <div class="mt-4 rounded-2xl bg-kyudo-gm-light-grey p-4 text-sm text-kyudo-gm-dark">
            <div class="text-xs font-medium text-">Club emprunteur</div>
            <div class="mt-1 font-semibold text-kyudo-gm-dark">
              {{ equipment.borrowerClub ? equipment.borrowerClub.name : '-' }}
            </div>

            <div class="mt-4 text-xs font-medium text-">Emprunté par (personne)</div>
            <div class="mt-1 font-semibold text-kyudo-gm-dark">
              {{ equipment.borrowerMember ? equipment.borrowerMember.fullName : '-' }}
            </div>
          </div>

          <p class="mt-3 text-xs text-">
            L'emprunteur est optionnel. Si aucun club n'est renseigné, l'équipement est considéré disponible.
          </p>

          {# --- QR Code --- #}
          <div class="mt-6 border-t border-kyudo-gm-light-grey pt-5">
            <h2 class="text-base font-semibold text-kyudo-gm-dark">QR Code</h2>

            {% if equipment.qrCode %}
              {% set qrCode = equipment.qrCode %}
              <div class="mt-3 flex flex-col items-center">
                {# Rendu SVG inline via le controller dédié #}
                <a href="{{ path('qr_code.show', {'uuid': qrCode.uuid}) }}" title="Voir le QR code">
                  <img
                    src="{{ path('qr_code.svg', {'uuid': qrCode.uuid}) }}"
                    alt="QR code équipement #{{ equipment.id }}"
                    class="w-40 h-40 rounded-xl border border-kyudo-gm-light-grey p-1 hover:shadow-md transition"
                  >
                </a>
                <div class="mt-3 flex gap-2">
                  <a
                    href="{{ path('qr_code.show', {'uuid': qrCode.uuid}) }}"
                    class="rounded-xl border border-kyudo-gm-light-grey bg-kyudo-white px-3 py-2 text-xs font-medium text-kyudo-gm-dark hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)"
                  >
                    Détails
                  </a>
                  <a
                    href="{{ path('qr_code.download_pdf', {'uuid': qrCode.uuid}) }}"
                    class="rounded-xl bg-kyudo-blue px-3 py-2 text-xs font-medium text-(--color-kyudo-white) hover:bg-kyudo-royal-blue"
                  >
                    PDF
                  </a>
                </div>
              </div>
            {% else %}
                <div class="mt-3 flex flex-col items-center gap-3">
                <div class="w-40 h-40 rounded-xl border-2 border-dashed border-kyudo-gm-light-grey flex items-center justify-center text-kyudo-gm-grey text-xs text-center p-4">
                  Aucun QR code généré
                </div>
                {% if is_granted('CREATE_QRCODE') %}
                <form method="post" action="{{ path('qr_code.generate_for_equipment', {'equipmentId': equipment.id}) }}">
                  <input type="hidden" name="_token" value="{{ csrf_token('generate_qr_' ~ equipment.id) }}">
                  <button
                    type="submit"
                    class="inline-flex items-center justify-center rounded-2xl bg-kyudo-blue px-4 py-2 text-sm font-medium text-(--color-kyudo-white) shadow-sm hover:bg-kyudo-royal-blue"
                  >
                    + Générer un QR code
                  </button>
                </form>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </aside>
      </div>

    </div>
  </div>
{% endblock %}

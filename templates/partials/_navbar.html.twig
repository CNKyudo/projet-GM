<nav class="sticky top-0 z-50 bg-kyudo-white shadow">
	{% set current_route = app.request.attributes.get('_route') %}
	{% set is_profile_route = current_route in ['user_profile', 'user_profile_edit', 'user_change_password'] %}

	<div class="mx-auto max-w-7xl px-4">
		<div class="flex h-16 items-center justify-between gap-3">
			<a href="{{ path('app_home') }}" class="min-w-0 truncate text-sm font-semibold sm:text-base {{ current_route == 'app_home' ? 'text-kyudo-royal-blue' : 'text-kyudo-gm-grey hover:text-kyudo-washed-blue' }}">
				<span class="sm:hidden">France Kyudo 仏国弓道 フランス きゅうど</span>
				<span class="hidden sm:inline">France Kyudo 仏国弓道 フランス きゅうど</span>
			</a>

			<div class="hidden items-center space-x-3 md:flex">
				<a href="{{ path('app_home') }}" class="rounded-md px-3 py-1 text-sm font-medium {{ current_route starts with 'app_home' ? 'bg-kyudo-blue text-(--color-kyudo-white) hover:bg-kyudo-royal-blue' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">
					Accueil
				</a>
				<a href="{{ path('equipment.index') }}" class="rounded-md px-3 py-1 text-sm font-medium {{ current_route starts with 'equipment' ? 'bg-kyudo-blue text-(--color-kyudo-white) hover:bg-kyudo-royal-blue' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">
					Equipements
				</a>
				<a href="{{ path('club_index') }}" class="rounded-md px-3 py-1 text-sm font-medium {{ current_route starts with 'club_' ? 'bg-kyudo-blue text-(--color-kyudo-white) hover:bg-kyudo-royal-blue' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">
					Clubs
				</a>
				<a href="{{ path('address_index') }}" class="rounded-md px-3 py-1 text-sm font-medium {{ current_route starts with 'address_' ? 'bg-kyudo-blue text-(--color-kyudo-white) hover:bg-kyudo-royal-blue' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">
					Adresses
				</a>
			</div>

			<div class="hidden items-center space-x-3 md:flex">
				{% if app.user %}
					<span class="max-w-[14rem] truncate text-sm text-kyudo-gm-grey">Bonjour
						{{ app.user.email }}</span>
					<a href="{{ path('user_profile') }}" class="rounded-md px-3 py-1 text-sm font-medium {{ is_profile_route ? 'bg-kyudo-blue text-(--color-kyudo-white) hover:bg-kyudo-royal-blue' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">
						Mon profil
					</a>
					<a href="{{ path('app_logout') }}" class="rounded-md bg-kyudo-white px-3 py-1 text-sm font-medium text-red-600 hover:bg-red-600 hover:text-(--color-kyudo-white)">
						Deconnexion
					</a>
				{% else %}
					<a href="{{ path('app_login') }}" class="text-sm text-kyudo-gm-grey hover:text-kyudo-royal-blue">Connexion</a>
					<a href="{{ path('app_register') }}" class="rounded-md bg-kyudo-blue px-3 py-1 text-sm text-(--color-kyudo-white) hover:bg-kyudo-royal-blue">Inscription</a>
				{% endif %}
			</div>

			<button id="navbar_mobile_toggle" type="button" class="cursor-pointer inline-flex items-center rounded-md border border-kyudo-gm-light-grey px-3 py-2 text-sm font-medium text-kyudo-gm-grey md:hidden" aria-expanded="false" aria-controls="navbar_mobile_menu">
				Menu
			</button>
		</div>

		<div id="navbar_mobile_menu" class="hidden border-t border-kyudo-gm-light-grey pb-4 pt-3 md:hidden">
			<div class="flex flex-col gap-2">
				<a href="{{ path('app_home') }}" class="rounded-md px-3 py-2 text-sm font-medium {{ current_route starts with 'app_home' ? 'bg-kyudo-blue text-(--color-kyudo-white)' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">Accueil</a>
				<a href="{{ path('equipment.index') }}" class="rounded-md px-3 py-2 text-sm font-medium {{ current_route starts with 'equipment' ? 'bg-kyudo-blue text-(--color-kyudo-white)' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">Equipements</a>
				<a href="{{ path('club_index') }}" class="rounded-md px-3 py-2 text-sm font-medium {{ current_route starts with 'club_' ? 'bg-kyudo-blue text-(--color-kyudo-white)' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">Clubs</a>
				<a href="{{ path('address_index') }}" class="rounded-md px-3 py-2 text-sm font-medium {{ current_route starts with 'address_' ? 'bg-kyudo-blue text-(--color-kyudo-white)' : 'text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">Adresses</a>
			</div>

			<div class="mt-3 border-t border-kyudo-gm-light-grey pt-3">
				{% if app.user %}
					<div class="px-3 pb-2 text-sm text-kyudo-gm-grey">Bonjour
						{{ app.user.email }}</div>
					<a href="{{ path('user_profile') }}" class="mx-3 mb-2 inline-flex rounded-md px-3 py-2 text-sm font-medium {{ is_profile_route ? 'bg-kyudo-blue text-(--color-kyudo-white)' : 'border border-kyudo-gm-light-grey text-kyudo-gm-grey hover:bg-kyudo-washed-blue hover:text-(--color-kyudo-white)' }}">Mon profil</a>
					<a href="{{ path('app_logout') }}" class="mx-3 inline-flex rounded-md bg-kyudo-white px-3 py-2 text-sm font-medium text-red-600 hover:bg-red-600 hover:text-(--color-kyudo-white)">Deconnexion</a>
				{% else %}
					<div class="flex gap-2 px-3">
						<a href="{{ path('app_login') }}" class="rounded-md border border-kyudo-gm-light-grey px-3 py-2 text-sm text-kyudo-gm-grey">Connexion</a>
						<a href="{{ path('app_register') }}" class="rounded-md bg-kyudo-blue px-3 py-2 text-sm text-(--color-kyudo-white)">Inscription</a>
					</div>
				{% endif %}
			</div>
		</div>
	</div>

	<script>
		(function () {
const button = document.getElementById('navbar_mobile_toggle');
const menu = document.getElementById('navbar_mobile_menu');

if (! button || ! menu) {
return;
}

button.addEventListener('click', function () {
const isOpen = ! menu.classList.contains('hidden');
menu.classList.toggle('hidden', isOpen);
button.setAttribute('aria-expanded', String(! isOpen));
});
})();
	</script>
</nav>

{% set palette = {
  success: {
    shell: 'border-emerald-200 bg-emerald-50/95 text-emerald-950',
    badge: 'bg-emerald-100 text-emerald-700',
    icon: 'OK',
    title: 'Succès'
  },
  error: {
    shell: 'border-red-200 bg-red-50/95 text-red-950',
    badge: 'bg-red-100 text-red-700',
    icon: '!',
    title: 'Erreur'
  },
  danger: {
    shell: 'border-red-200 bg-red-50/95 text-red-950',
    badge: 'bg-red-100 text-red-700',
    icon: '!',
    title: 'Erreur'
  },
  warning: {
    shell: 'border-amber-200 bg-amber-50/95 text-amber-950',
    badge: 'bg-amber-100 text-amber-700',
    icon: '!',
    title: 'Attention'
  },
  info: {
    shell: 'border-blue-200 bg-blue-50/95 text-blue-950',
    badge: 'bg-blue-100 text-blue-700',
    icon: 'i',
    title: 'Information'
  },
  reset_password_error: {
    shell: 'border-red-200 bg-red-50/95 text-red-950',
    badge: 'bg-red-100 text-red-700',
    icon: '!',
    title: 'Erreur'
  }
} %}

<div id="flash_toasts" class="pointer-events-none flex w-[min(92vw,26rem)] flex-col gap-3" style="position: fixed; top: 5rem; right: 1rem; z-index: 9999;">
	{% for type, messages in app.flashes %}
		{% set variant = palette[type]|default({
      shell: 'border-kyudo-gm-light-grey bg-kyudo-white/95 text-kyudo-gm-dark',
      badge: 'bg-kyudo-gm-light-grey text-kyudo-gm-grey',
      icon: 'i',
      title: 'Message'
    }) %}
		{% for message in messages %}
			<div class="flash-toast pointer-events-auto overflow-hidden rounded-2xl border shadow-xl ring-1 ring-black/5 backdrop-blur transition duration-300 {{ variant.shell }}" role="{{ type in ['error', 'danger', 'warning', 'reset_password_error'] ? 'alert' : 'status' }}" aria-live="polite">
				<div class="h-1 w-full {{ variant.badge }}"></div>
				<div class="flex items-start gap-3 px-4 py-4">
					<span class="inline-flex h-8 min-w-8 items-center justify-center rounded-full px-2 text-xs font-bold {{ variant.badge }}">
						{{ variant.icon }}
					</span>
					<div class="min-w-0 flex-1">
						<p class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] opacity-80">{{ variant.title }}</p>
						<p class="mt-1 text-sm font-medium leading-6">{{ message }}</p>
					</div>
					<button type="button" class="cursor-pointer rounded-full p-2 text-xs font-semibold opacity-60 transition hover:bg-black/5 hover:opacity-100" data-flash-dismiss aria-label="Fermer">
						x
					</button>
				</div>
			</div>
		{% endfor %}
	{% endfor %}
</div>
